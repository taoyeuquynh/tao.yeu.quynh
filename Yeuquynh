end
local function FindTeleTarget() if AimTargetName=="" then return nil end return FindPlayer(AimTargetName) end

--// AIM LOCK
local function GetAimTarget()
    local c=Player.Character if not c or not c:FindFirstChild("HumanoidRootPart") then return nil end
    if AimTargetName~="" then local t=FindTeleTarget() if t then return t end end
    local rp=c.HumanoidRootPart.Position; local cam=workspace.CurrentCamera
    local cp=cam.CFrame.Position; local cl=cam.CFrame.LookVector
    local best,bestScore=nil,-999999
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl~=Player and not AimProtected[pl.Name] and pl.Character and pl.Character:FindFirstChild("Humanoid") and pl.Character.Humanoid.Health>0 then
            local hr=pl.Character:FindFirstChild("HumanoidRootPart"); local hd=pl.Character:FindFirstChild("Head")
            if hr then local tp=hd and hd.Position or (hr.Position+Vector3.new(0,2,0))
                local d=(hr.Position-rp).Magnitude if d<AIM_RANGE then
                    local dir=(tp-cp).Unit; local a=math.acos(math.clamp(dir:Dot(cl),-1,1))
                    if a<=math.rad(AIM_FOV) then local s=(2000-d)-(math.deg(a)*10)
                        if s>bestScore then bestScore=s best=pl end end end end end end
    return best
end

local function AimLockUpdate()
    if not IsAimLock then return end
    if AimTarget then local v=false
        if AimTarget.Character and AimTarget.Character:FindFirstChild("Humanoid") and AimTarget.Character.Humanoid.Health>0 then
            local c=Player.Character if c and c:FindFirstChild("HumanoidRootPart") and AimTarget.Character:FindFirstChild("HumanoidRootPart") then
                if (AimTarget.Character.HumanoidRootPart.Position-c.HumanoidRootPart.Position).Magnitude<AIM_RANGE then v=true end end end
        if not v then AimTarget=nil AimLastPos=nil end end
    if not AimTarget then AimTarget=GetAimTarget() end
    if AimTarget then AimInfo.Text="🎯 "..AimTarget.DisplayName AimInfo.TextColor3=Color3.fromRGB(100,255,100)
    else AimInfo.Text="🔍 ĐANG QUÉT..." AimInfo.TextColor3=Color3.fromRGB(200,200,200) end
    if AimTarget and AimTarget.Character then
        local hd=AimTarget.Character:FindFirstChild("Head"); local hr=AimTarget.Character:FindFirstChild("HumanoidRootPart")
        local hm=AimTarget.Character:FindFirstChild("Humanoid")
        local cp=hd and hd.Position or (hr and hr.Position+Vector3.new(0,2,0)) if not cp then return end
        local v=Vector3.zero if AimLastPos and hr then local dt=0.016 if dt>0 then v=(hr.Position-AimLastPos)/dt end end
        if hm and hm.MoveDirection.Magnitude>0 then v=hm.MoveDirection*hm.WalkSpeed end
        workspace.CurrentCamera.CFrame=CFrame.lookAt(workspace.CurrentCamera.CFrame.Position,cp+(v*0.1))
        if hr then AimLastPos=hr.Position end
    end
end

local function StartAimLock() IsAimLock=true AimTarget=GetAimTarget() AimLastPos=nil if AimConnection then AimConnection:Disconnect() end AimConnection=RunService.RenderStepped:Connect(AimLockUpdate) end
local function StopAimLock() IsAimLock=false AimTarget=nil AimLastPos=nil if AimConnection then AimConnection:Disconnect() AimConnection=nil end AimInfo.Text="🎯 CHƯA CÓ MỤC TIÊU" AimInfo.TextColor3=Color3.fromRGB(200,200,200) end

--// TELEPORT
local function TeleportToTarget()
    local c=Player.Character if not c or not c:FindFirstChild("HumanoidRootPart") then return end local hr=c.HumanoidRootPart
    if not TeleTarget or not TeleTarget.Character or not TeleTarget.Character:FindFirstChild("Humanoid") or TeleTarget.Character.Humanoid.Health<=0 then TeleTarget=FindTeleTarget() end
    if not TeleTarget and AimTargetName=="" then local n,nd=nil,999
        for _,p in pairs(Players:GetPlayers()) do if p~=Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health>0 then local d=(p.Character.HumanoidRootPart.Position-hr.Position).Magnitude if d<nd then n=p nd=d end end end TeleTarget=n end
    if not TeleTarget or not TeleTarget.Character or not TeleTarget.Character:FindFirstChild("HumanoidRootPart") then return end local tr=TeleTarget.Character.HumanoidRootPart
    local fp if BMode==1 then fp=tr.Position+(-tr.CFrame.LookVector*2)
    elseif BMode==2 then fp=tr.Position+(tr.CFrame.LookVector*2)
    elseif BMode==3 then fp=tr.Position+Vector3.new(0,3,0)
    elseif BMode==4 then local a=math.random()*math.pi*2 fp=tr.Position+Vector3.new(math.cos(a)*3,0.5,math.sin(a)*3)
    else local t=tick()*3 fp=tr.Position+Vector3.new(math.cos(t)*3,0.5,math.sin(t)*3) end
    hr.CFrame=CFrame.new(fp,tr.Position) hr.AssemblyLinearVelocity=Vector3.zero hr.AssemblyAngularVelocity=Vector3.zero
    for _,v in pairs(c:GetDescendants()) do if v:IsA("BasePart") then v.AssemblyLinearVelocity=Vector3.zero v.AssemblyAngularVelocity=Vector3.zero end end
    if IsAutoBlock then BlockDisabledUntil=tick()+0.3 end
end

--// EXTEND REACH
local function ExtendReach()
    if not IsReach then return end local c=Player.Character if not c then return end local rp=c:FindFirstChild("HumanoidRootPart") if not rp then return end
    local n,nd=nil,ReachDistance
    for _,pl in ipairs(Players:GetPlayers()) do if pl~=Player and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") and pl.Character:FindFirstChild("Humanoid") and pl.Character.Humanoid.Health>0 then local d=(pl.Character.HumanoidRootPart.Position-rp.Position).Magnitude if d<nd then n=pl nd=d end end end
    if n and n.Character and n.Character:FindFirstChild("HumanoidRootPart") then local tr=n.Character.HumanoidRootPart tr.CFrame=CFrame.new(rp.Position-(rp.Position-tr.Position).Unit*3,tr.Position) tr.AssemblyLinearVelocity=Vector3.zero end
end

