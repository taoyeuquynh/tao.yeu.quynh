--// BRING SYSTEM
local BringTargets = {}

local function StartBring(targetPlayer)
    if not targetPlayer then return end
    if not table.find(BringTargets, targetPlayer) then
        table.insert(BringTargets, targetPlayer)
    end
end

local function StopBring(targetPlayer)
    if targetPlayer then
        for i, p in pairs(BringTargets) do
            if p == targetPlayer then
                table.remove(BringTargets, i)
                if targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local root = targetPlayer.Character.HumanoidRootPart
                    if root:FindFirstChild("BringForce") then root.BringForce:Destroy() end
                    if root:FindFirstChild("BringAtt") then root.BringAtt:Destroy() end
                end
                break
            end
        end
    else
        for _, p in pairs(BringTargets) do
            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local root = p.Character.HumanoidRootPart
                if root:FindFirstChild("BringForce") then root.BringForce:Destroy() end
                if root:FindFirstChild("BringAtt") then root.BringAtt:Destroy() end
            end
        end
        BringTargets = {}
    end
end

local function CleanOtherPhysics(root)
    for _, v in pairs(root:GetChildren()) do
        if (v:IsA("BodyMover") or v:IsA("LinearVelocity") or v:IsA("VectorForce") or v:IsA("AlignPosition")) 
        and v.Name ~= "BringForce" and v.Name ~= "BringAtt" then
            v:Destroy()
        end
    end
end

--// WHITELIST BV SYSTEM
local WhitelistBV = {}
local BV_Enabled = true

local mt = getrawmetatable(game)
setreadonly(mt, false)
local old = mt.__namecall
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = { ... }
    if BV_Enabled and (method == "FireServer" or method == "InvokeServer") then
        for _, p in pairs(WhitelistBV) do
            if p and p.Character then
                for _, v in pairs(args) do
                    if v == p or v == p.Character or (type(v) == "table" and rawget(v, "Instance") == p.Character) then
                        return nil
                    end
                end
            end
        end
    end
    return old(self, ...)
end)
setreadonly(mt, true)

local function FindPlayerBV(name)
    name = name:lower()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Player and (p.Name:lower():find(name) or p.DisplayName:lower():find(name)) then
            return p
        end
    end
    return nil
end

