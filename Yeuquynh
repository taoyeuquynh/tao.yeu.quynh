RunService.RenderStepped:Connect(function()
    for _, target in pairs(BringTargets) do
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local myChar = Player.Character
            if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then continue end
            
            local myRoot = myChar.HumanoidRootPart
            local targetRoot = target.Character.HumanoidRootPart
            local targetCFrame = myRoot.CFrame * CFrame.new(0, 0, -5)
            
            CleanOtherPhysics(targetRoot)
            
            local dist = (targetCFrame.p - targetRoot.Position).Magnitude
            
            local att = targetRoot:FindFirstChild("BringAtt") or Instance.new("Attachment", targetRoot)
            att.Name = "BringAtt"
            local lv = targetRoot:FindFirstChild("BringForce") or Instance.new("LinearVelocity", targetRoot)
            lv.Name = "BringForce"
            lv.MaxForce = 9999999
            lv.Attachment0 = att

            if dist > 20 then
                lv.VectorVelocity = (targetCFrame.p - targetRoot.Position).Unit * 200
            else
                targetRoot.CFrame = targetCFrame
                lv.VectorVelocity = Vector3.new(0,0,0)
                targetRoot.Velocity = Vector3.new(0,0,0)
                targetRoot.RotVelocity = Vector3.new(0,0,0)
            end
            
            for _, v in pairs(target.Character:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end
end)

