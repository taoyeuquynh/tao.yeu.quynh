                pcall(function() t:Kick("❌ BẠN KHÔNG PHẢI TEAM HTGMX, KHÔNG PHẬN SỰ!") end)
            end
        elseif cmd == "unblacklist" and args[2] then
            local t = FindPlayer(args[2])
            if t then Blacklist[t.Name] = nil end
        elseif cmd == "unblacklistall" then
            Blacklist = {}
        end
    end)
end

