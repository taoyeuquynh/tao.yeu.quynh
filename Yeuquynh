--// ESP SYSTEM
local ESP_ENABLED = true
local ESP_Objects = {}

local function CreateESP(t)
    if not t.Character then return end
    local h = t.Character:FindFirstChild("Head") if not h then return end
    local hl = Instance.new("Highlight", t.Character)
    hl.Name="ESP"; hl.FillColor=Color3.fromRGB(255,50,50); hl.FillTransparency=0.5
    hl.OutlineColor=Color3.fromRGB(255,255,255); hl.Adornee=t.Character
    hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Enabled=ESP_ENABLED
    local bb = Instance.new("BillboardGui", h)
    bb.Name="ESP_BB"; bb.Size=UDim2.new(0,200,0,30); bb.StudsOffset=Vector3.new(0,3,0)
    bb.AlwaysOnTop=true; bb.Enabled=ESP_ENABLED
    local nl = Instance.new("TextLabel", bb)
    nl.Size=UDim2.new(1,0,0,16); nl.BackgroundTransparency=1; nl.Text=t.DisplayName
    nl.TextColor3=Color3.new(1,1,1); nl.Font=Enum.Font.GothamBold; nl.TextSize=12
    local dl = Instance.new("TextLabel", bb)
    dl.Size=UDim2.new(1,0,0,14); dl.Position=UDim2.new(0,0,0,16); dl.BackgroundTransparency=1
    dl.TextColor3=Color3.fromRGB(255,200,50); dl.Font=Enum.Font.GothamBold; dl.TextSize=10
    local hb = Instance.new("Frame", bb)
    hb.Size=UDim2.new(1,0,0,3); hb.Position=UDim2.new(0,0,0,29); hb.BackgroundColor3=Color3.fromRGB(50,50,50)
    local hf = Instance.new("Frame", hb)
    hf.Size=UDim2.new(1,0,1,0); hf.BackgroundColor3=Color3.fromRGB(0,255,0)
    table.insert(ESP_Objects,{Target=t,Highlight=hl,Billboard=bb,DistLabel=dl,HealthFill=hf})
end

local function RemoveESP(t)
    for i,e in pairs(ESP_Objects) do if e.Target==t then e.Highlight:Destroy() e.Billboard:Destroy() table.remove(ESP_Objects,i) break end end
    if t.Character then pcall(function() t.Character.ESP:Destroy() end) pcall(function() t.Character.Head.ESP_BB:Destroy() end) end
end

local function ClearAllESP()
    for _,e in pairs(ESP_Objects) do pcall(function() e.Highlight:Destroy() e.Billboard:Destroy() end) end
    ESP_Objects={}
    for _,p in pairs(Players:GetPlayers()) do if p~=Player and p.Character then pcall(function() p.Character.ESP:Destroy() p.Character.Head.ESP_BB:Destroy() end) end end
end

local function RefreshESP()
    ClearAllESP() if not ESP_ENABLED then return end
    for _,p in pairs(Players:GetPlayers()) do if p~=Player and p.Character and p.Character:FindFirstChild("Head") then CreateESP(p) end end
end

local function UpdateESP()
    if not ESP_ENABLED then return end
    for _,e in pairs(ESP_Objects) do
        if e.Target.Character and e.Target.Character:FindFirstChild("HumanoidRootPart") and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            local d=(e.Target.Character.HumanoidRootPart.Position-Player.Character.HumanoidRootPart.Position).Magnitude
            e.DistLabel.Text=math.floor(d).."m"
            local hp=e.Target.Character.Humanoid.Health/e.Target.Character.Humanoid.MaxHealth
            e.HealthFill.Size=UDim2.new(hp,0,1,0)
            e.HealthFill.BackgroundColor3=hp>0.5 and Color3.fromRGB(0,255,0) or hp>0.25 and Color3.fromRGB(255,200,0) or Color3.fromRGB(255,0,0)
        end
    end
end

